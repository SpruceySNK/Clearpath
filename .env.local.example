# Cloudflare Account
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# Environment
TF_VAR_environment=dev
TF_VAR_account_id=your_account_id
TF_VAR_api_token=your_api_token

# Autonomy Level (1-5)
# 1 = No AI review, human only
# 2 = AI recommends, human decides
# 3 = AI acts on high confidence, defers on low
# 4 = Full AI autonomy with real-time notifications
# 5 = Full AI autonomy with periodic audit only
TF_VAR_autonomy_level=3

# CLI
# The CLI auto-loads this file on startup — set the URL to your deployed
# orchestrator worker so you don't need to export it manually each session.
# Find your worker URL in Terraform outputs: npm run deploy → orchestrator_url
CLEARPATH_API_URL=https://clearpath-dev-orchestrator.your-subdomain.workers.dev
